// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "auto_install_extensions": {
    "codebook": true,
    "colored-zed-icons-theme": true,
    "fish": true,
    "git-firefly": true,
    "html": true,
    "log": true,
    "rainbow-csv": true,
    "swift": true,
    "toml": true,
    "tsgo": true,
    "zed-legacy-themes": true,
  },
  "cli_default_open_behavior": "existing_window",
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "code_lens": "on",
  "project_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "edit_predictions": {
    "provider": "none",
  },
  "use_system_window_tabs": false,
  "tab_bar": {
    "show_nav_history_buttons": true,
    "show": true,
  },
  "buffer_line_height": { "custom": 2 },
  "ui_font_family": "Lilex",
  "soft_wrap": "editor_width",
  "minimap": {
    "show": "always",
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "all",
  },
  "terminal": {
    "dock": "right",
    "line_height": "comfortable",
  },
  "inlay_hints": {
    "enabled": true,
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  "theme": {
    "mode": "dark",
    "light": "Zed Legacy: Rosé Pine Dawn",
    "dark": "Zed Legacy: Rosé Pine",
  },
  "languages": {
    "HTML": {
      "tab_size": 2,
    },
    "CSS": {
      "tab_size": 2,
    },
    "JavaScript": {
      "inlay_hints": {
        "enabled": false,
      },
    },
    "TypeScript": {
      "inlay_hints": {
        "enabled": false,
      },
    },
  },
  "language_servers": [
    "tsgo",
    "!vtsls",
    "!eslint",
    "!typescript-language-server",
    "!tailwindcss-language-server",
    "...",
  ],
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
          "extraArgs": ["--profile", "clippy"],
        },
        "cargo": {
          "features": "all",
          "targetDir": true,
        },
      },
    },
  },

  // ---
  // Hide useless stuff
  // ---

  "search": {
    "button": false,
  },
  "outline_panel": {
    "button": false,
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "disable_ai": true,
  "title_bar": {
    "show_onboarding_banner": false,
    "show_sign_in": false,
    "show_user_picture": false,
  },
  "agent": {
    "button": false,
    "enabled": false,
  },
  "collaboration_panel": {
    "button": false,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}
